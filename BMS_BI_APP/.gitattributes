# ==========================================
# GENERAL TEXT AUTO-DETECT
# ==========================================
* text=auto eol=lf

# ==========================================
# VUE, JAVASCRIPT, TYPESCRIPT CODE
# ==========================================
*.vue text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# ==========================================
# MEDIA AND BINARY PRESERVATION
# ==========================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf

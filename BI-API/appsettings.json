{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Server": {
    "Host": "0.0.0.0",
    "Port": 8001
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:8002",
      "http://localhost:8002",
      "http://127.0.0.1:8002",
      "https://localhost:8888",
      "http://localhost:8888",
      "http://127.0.0.1:8888",
      "https://localhost:8889",
      "http://localhost:8889",
      "http://127.0.0.1:8889"
    ]
  },
  "Jwt": {
    "AccessTokenExpireMinutes": 15,
    "CookieExpireHours": 1
  },
  "Manager": {
    "Port": 8003
  },
  "Config": {
    "ReferenceDir": "./assets",
    "CentralDbPath": "./assets/BMS_BI_Central.db"
  }
}